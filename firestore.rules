rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Server Webhook auth checking bypass:
    function isWebhookCreate() {
      return incoming().keys().hasAll(['isWebhook']) 
          && incoming().isWebhook == true 
          && incoming().keys().hasAll(['webhookSecret'])
          && incoming().webhookSecret == "server_secret_for_webhook"
          && incoming().keys().size() <= 9; // allow all other valid fields
    }

    function isValidSignalCreate(data) {
      return data.keys().hasAll(['pair', 'signal', 'entry', 'takeProfit', 'stopLoss', 'timestamp'])
        && data.pair is string
        && data.pair.size() <= 20
        && data.signal is string
        && (data.signal == 'BUY' || data.signal == 'SELL')
        && data.entry is number
        && data.takeProfit is number
        && data.stopLoss is number
        && data.timestamp is number
        // either standard signed in creation OR webhook creation bypass
        && (
            (isAdmin() && data.keys().hasAll(['createdBy']) && data.createdBy == request.auth.uid) ||
            isWebhookCreate()
        );
    }
    
    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;

      function isValidUserDoc() {
        return incoming().keys().hasAll(['email', 'createdAt'])
          && incoming().keys().hasOnly(['email', 'createdAt', 'isAdmin'])
          && incoming().email is string
          && incoming().email.size() <= 200
          && incoming().createdAt is number;
      }

      allow create: if isSignedIn() 
        && request.auth.uid == userId 
        && isValidUserDoc()
        && (!incoming().keys().hasAny(['isAdmin']) || incoming().isAdmin == false || incoming().email == 'cerezvincent1@gmail.com');

      allow update: if isSignedIn() 
        && request.auth.uid == userId 
        && isValidUserDoc()
        && (!incoming().keys().hasAny(['isAdmin']) || incoming().isAdmin == false || incoming().email == 'cerezvincent1@gmail.com');
    }

    match /signals/{signalId} {
      // Prompt: Only authenticated users can read 'signals'.
      allow read: if isSignedIn();
      allow list: if isSignedIn();
      
      allow create: if isValidId(signalId) && isValidSignalCreate(incoming());
      
      // We don't necessarily need update/delete for this basic app, so deny.
      allow update, delete: if false;
    }
  }
}
